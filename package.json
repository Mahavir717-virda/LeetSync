{
  "name": "leetsync",
  "version": "1.0.0",
  "description": "Sync LeetCode submissions to GitHub with full version history. Never lose a submission again.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/cleanup-build.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "idb": "^8.0.2",
    "preact": "^10.25.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.32",
    "@preact/preset-vite": "^2.9.0",
    "@types/chrome": "^0.0.306",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
