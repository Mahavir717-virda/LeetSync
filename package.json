{
  "name": "gitsolve",
  "version": "1.0.0",
  "description": "Sync LeetCode submissions to GitHub with full version history. Never lose a submission again.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/cleanup-build.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "autoprefixer": "^10.5.4",
    "canvas-confetti": "^1.9.4",
    "idb": "^8.0.2",
    "lottie-web": "^5.13.0",
    "lucide-preact": "^1.25.0",
    "neo4j-driver": "^6.2.0",
    "postcss": "^8.5.22",
    "preact": "^10.25.0",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.32",
    "@preact/preset-vite": "^2.9.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/chrome": "^0.0.306",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
